# ============================================================================
# LLM API Configuration
# ============================================================================
# Supports: OpenAI, Azure OpenAI, OpenRouter, Claude, or any OpenAI-compatible API
#
# For OpenAI API:
#   LLM_API_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL_NAME=gpt-4
#
# For Azure OpenAI:
#   LLM_API_BASE_URL=https://YOUR-RESOURCE.openai.azure.com/
#   LLM_API_VERSION=2024-12-01-preview
#   LLM_MODEL_NAME=your-deployment-name
#
# For OpenRouter:
#   LLM_API_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL_NAME=openai/gpt-4
#
# For Anthropic Claude:
#   LLM_API_BASE_URL=https://api.anthropic.com/v1
#   LLM_MODEL_NAME=claude-3-opus-20240229

LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_API_VERSION=2024-01-01
LLM_MODEL_NAME=gpt-4
EMBEDDING_MODEL_NAME=text-embedding-3-large

# ============================================================================
# Optional: Alternative LLM Provider (for fallback or specific tasks)
# ============================================================================
# FALLBACK_LLM_API_BASE_URL=https://openrouter.ai/api/v1
# FALLBACK_LLM_API_KEY=your-openrouter-key
# FALLBACK_LLM_MODEL_NAME=anthropic/claude-3-sonnet

# ============================================================================
# Database
# ============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/job_predator
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/job_predator

# ============================================================================
# Job Platform Credentials (optional)
# ============================================================================
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

STEPSTONE_EMAIL=your_stepstone_email@example.com
STEPSTONE_PASSWORD=your_stepstone_password

INDEED_EMAIL=your_indeed_email@example.com
INDEED_PASSWORD=your_indeed_password

XING_EMAIL=your_xing_email@example.com
XING_PASSWORD=your_xing_password

# ============================================================================
# GitHub API (for job mining)
# Get token at: https://github.com/settings/tokens
# ============================================================================
GITHUB_TOKEN=your_github_token_here

# ============================================================================
# Hunter.io API (for HR email finding)
# Free tier: 25 searches/month
# Get yours at: https://hunter.io/api-keys
# ============================================================================
HUNTER_API_KEY=your_hunter_api_key_here

# ============================================================================
# Email Outreach (SMTP)
# For Gmail: create App Password at https://myaccount.google.com/apppasswords
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
EMAIL_FROM=Your Name <your_email@gmail.com>

# ============================================================================
# File Paths
# ============================================================================
CV_PDF_PATH=./user_documents/cv.pdf
CV_LATEX_PATH=./user_documents/cv.tex

# ============================================================================
# Scraping Behavior
# ============================================================================
SCRAPE_MAX_RESULTS=50
SCRAPE_HOURS_OLD=72
# SCRAPE_PROXY=http://user:pass@proxy.host:port

# ============================================================================
# Application Behavior
# ============================================================================
# Minimum LLM match score (0-10) to auto-apply
AUTO_APPLY_THRESHOLD=7.0
# Pause for human review before submission
HUMAN_REVIEW=True
# Show browser window for debugging
HEADLESS_BROWSER=False

# ============================================================================
# Local Embedding Model
# Downloads on first run (~90MB), no API cost
# ============================================================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
